{
  "basal_rules": {
    "ignore_folders": [
      "__pycache__",
      "node_modules",
      "dist",
      "build",
      "venv",
      ".venv",
      ".git",
      ".map",
      ".claude",
      "_archivo",
      "out",
      ".next",
      "src-tauri/target",
      "target",
      "gen",
      "bin",
      "obj",
      "vendor"
    ],
    "text_extensions": [
      ".py",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".php",
      ".html",
      ".htm",
      ".css",
      ".mjs",
      ".json",
      ".sql",
      ".env"
    ],
    "ignore_files": [],
    "ignore_patterns": [
      "*.min.js",
      "*.min.css",
      "*.bundle.js",
      ".env",
      ".env.*",
      ".gitignore",
      ".gitattributes",
      ".editorconfig",
      ".prettierrc",
      ".prettierrc.*",
      ".eslintrc",
      ".eslintrc.*"
    ],
    "asset_extensions": [
      ".jpg", ".jpeg", ".png", ".webp", ".svg", ".ico", ".gif", ".bmp",
      ".woff", ".woff2", ".ttf", ".otf", ".eot",
      ".mp4", ".webm", ".mov", ".avi",
      ".mp3", ".wav", ".ogg",
      ".pdf", ".zip", ".tar", ".gz"
    ]
  },
  "stack_markers": {
    "WordPress-Development": {
      "lock_files": ["composer.json"],
      "framework_markers": ["wp-config.php", "functions.php"],
      "content_markers": ["Plugin Name:", "Theme Name:"]
    },
    "Modern-Web-Stack": {
      "lock_files": ["package-lock.json", "yarn.lock", "pnpm-lock.yaml"],
      "framework_markers": ["next.config.js", "vite.config.ts", "tsconfig.json"],
      "content_markers": ["\"use client\"", "export default function"]
    },
    "Tauri-Desktop-App": {
      "lock_files": ["Cargo.lock"],
      "framework_markers": ["tauri.conf.json", "src-tauri/src/main.rs"],
      "content_markers": ["tauri::command", "window.__TAURI__"]
    },
    "AI-Agent-Framework": {
      "lock_files": ["requirements.txt", "pyproject.toml"],
      "framework_markers": ["bridge_windows.py", "indexar_filters.json"],
      "content_markers": ["def tool_", "def skill_"]
    },
    "Vanilla-Web-Stack": {
      "lock_files": [],
      "framework_markers": ["index.php", "index.html"],
      "content_markers": ["<?php", "document.addEventListener"]
    },
    "Python": {
      "extensions": [".py", ".pyi"]
    },
    "JavaScript": {
      "extensions": [".js", ".mjs", ".cjs", ".jsx"]
    },
    "TypeScript": {
      "extensions": [".ts", ".tsx"]
    },
    "PHP": {
      "extensions": [".php"]
    },
    "Ruby": {
      "extensions": [".rb"]
    },
    "Go": {
      "extensions": [".go"]
    },
    "Rust": {
      "extensions": [".rs"]
    },
    "Java": {
      "extensions": [".java"]
    },
    "Web-Static": {
      "extensions": [".html", ".htm", ".css"]
    }
  },
  "language_grammars": {
    "php": "tree_sitter_php",
    "javascript": "tree_sitter_javascript",
    "typescript": "tree_sitter_typescript",
    "python": "stdlib_ast",
    "html": "regex_only"
  },
  "scoring": {
    "network_triggers": [
      "http",
      "ws://",
      "api",
      "localhost",
      "fetch\\(",
      "wp_remote_",
      "requests\\.",
      "axios",
      "curl_init"
    ],
    "persistence_triggers": [
      "global \\$wpdb",
      "get_option",
      "sql",
      "SELECT ",
      "INSERT INTO",
      "fs\\.",
      "localStorage",
      "sessionStorage",
      "ChromaDB",
      "prisma",
      "PDO",
      "mysqli_"
    ],
    "identity_triggers": [
      "Plugin Name:",
      "export default function",
      "def main",
      "class ",
      "register_rest_route",
      "addEventListener",
      "index\\."
    ]
  },
  "graph": {
    "_unify_external_nodes_note": "PARCIAL: fallback para URLs dinamicas/variables no capturadas por NET-022 (URLs literales). Completar con SEM-020.",
    "unify_external_nodes": [
      "fetch",
      "anthropic",
      "chromadb",
      "openai",
      "axios",
      "requests"
    ],
    "ignore_outbound_patterns": [
      "^self$",
      "^none$",
      "^$"
    ],
    "rankdir": "LR",
    "vis_network_cdn_url": "https://unpkg.com/vis-network/standalone/umd/vis-network.min.js",
    "default_edge_type": "use",
    "edge_colors": {
      "import":  "#1f7a1f",
      "require": "#333333",
      "include": "#555555",
      "src":     "#1f5fbf",
      "href":    "#2e86de",
      "action":  "#8e44ad",
      "fetch":   "#c0392b",
      "enqueue": "#7d3c98",
      "use":     "#888888"
    },
    "node_colors": {
      "normal":   { "fillcolor": "#f5f5f5", "color": "#333333" },
      "orphan":   { "fillcolor": "#fff3cd", "color": "#b7791f" },
      "cycle":    { "fillcolor": "#fde0dc", "color": "#c0392b" },
      "external": { "fillcolor": "#ffcccc", "color": "#cc0000" }
    },
    "node_shapes": {
      "normal":   "box",
      "orphan":   "box",
      "cycle":    "box",
      "external": "cylinder"
    },
    "_external_tier_colors_note": "TIER-035: color por tier semántico del external. stdlib=gris neutro (ruido), package=azul (dep instalada), service=violeta (red externa), wrapper=ámbar (HTTP wrapper custom del proyecto).",
    "external_tier_colors": {
      "stdlib":  "#9ca3af",
      "package": "#60a5fa",
      "service": "#a78bfa",
      "wrapper": "#f59e0b"
    },
    "_external_wrappers_note": "TIER-035: nombres de funciones/identifiers que son wrappers HTTP custom del proyecto. Cuando un external promovido matchea uno de estos (por lenguaje o en 'any'), se clasifica como tier='wrapper' en vez de 'package'. Útil para apiReq/apiCall/etc.",
    "external_wrappers": {
      "any": [],
      "python": [],
      "javascript": [],
      "typescript": [],
      "php": []
    },
    "_entry_point_style_note": "GRAPH-036: estilo visual del nodo entry point (archivo ejecutable: __main__, index.php raíz, package.json main, ref desde .bat/.sh).",
    "entry_point_border_color": "#fbbf24",
    "entry_point_border_width": 4,
    "entry_point_size_boost": 10,
    "entry_point_label_prefix": ""
  },
  "scoring_weights": {
    "health_weights": {
      "orphans":       0.40,
      "connectivity":  0.30,
      "dead_exports":  0.15,
      "external_deps": 0.15
    }
  },
  "external_include_stdlib": false,
  "_path_functions_note": "SEM-020: funciones cuyo return-value semántico es un path conocido. El PathResolver las evalúa al ver `fn()` en una concatenación (php) o interpolación (js/php). Valor = template con tokens {theme_root}, {plugins_root}, {source_dir}. Cada token se resuelve en runtime: theme_root = dir del tema WP detectado (o project_root fallback); plugins_root = wp-content/plugins; source_dir = dir del archivo fuente.",
  "path_functions": {
    "get_template_directory_uri":    "{theme_root}",
    "get_template_directory":        "{theme_root}",
    "get_stylesheet_directory_uri":  "{theme_root}",
    "get_stylesheet_directory":      "{theme_root}",
    "plugins_url":                   "{plugins_root}",
    "plugin_dir_url":                "{plugins_root}",
    "plugin_dir_path":               "{plugins_root}",
    "__dirname":                     "{source_dir}"
  },
  "_loader_calls_note": "SEM-020: llamadas a funciones de carga de recursos. El scanner captura la llamada completa + el PathResolver extrae el argumento `arg` (1-based) y lo resuelve. `ext_default` se agrega si el string no termina en extensión conocida. Si `arg` es concatenación `fn() . 'literal'` o interpolación `\"$var/literal\"`, el resolver usa path_functions para evaluar la parte dinámica. Mini-S10.5: `arg: 0` = zero-arg call con path implícito (`path_template`), `path_template_with_arg` = variante cuando hay un string literal como argumento (ej. `get_header('alt')` → `header-alt.php`). `accepts_array: true` = el argumento puede ser un array literal PHP; se emite un edge por cada string del array.",
  "loader_calls": {
    "wp_enqueue_script":   { "arg": 2, "ext_default": ".js",  "language": "php", "edge_type": "enqueue" },
    "wp_enqueue_style":    { "arg": 2, "ext_default": ".css", "language": "php", "edge_type": "enqueue" },
    "wp_register_script":  { "arg": 2, "ext_default": ".js",  "language": "php", "edge_type": "enqueue" },
    "wp_register_style":   { "arg": 2, "ext_default": ".css", "language": "php", "edge_type": "enqueue" },
    "get_template_part":   { "arg": 1, "ext_default": ".php", "language": "php", "edge_type": "include", "base": "{theme_root}" },
    "locate_template":     { "arg": 1, "ext_default": ".php", "language": "php", "edge_type": "include", "base": "{theme_root}", "accepts_array": true },
    "get_header":          { "arg": 0, "language": "php", "edge_type": "include", "path_template": "{theme_root}/header.php",   "path_template_with_arg": "{theme_root}/header-{arg}.php" },
    "get_footer":          { "arg": 0, "language": "php", "edge_type": "include", "path_template": "{theme_root}/footer.php",   "path_template_with_arg": "{theme_root}/footer-{arg}.php" },
    "get_sidebar":         { "arg": 0, "language": "php", "edge_type": "include", "path_template": "{theme_root}/sidebar.php",  "path_template_with_arg": "{theme_root}/sidebar-{arg}.php" },
    "comments_template":   { "arg": 0, "language": "php", "edge_type": "include", "path_template": "{theme_root}/comments.php" }
  },
  "http_loaders": {
    "python": [
      "requests.get", "requests.post", "requests.put", "requests.delete",
      "requests.patch", "requests.head", "requests.options", "requests.request",
      "urlopen", "urllib.request.urlopen",
      "httpx.get", "httpx.post", "httpx.put", "httpx.delete",
      "httpx.patch", "httpx.head", "httpx.options", "httpx.request"
    ],
    "javascript": [
      "fetch",
      "axios.get", "axios.post", "axios.put", "axios.delete",
      "axios.patch", "axios.head", "axios.options", "axios.request", "axios"
    ],
    "typescript": [
      "fetch",
      "axios.get", "axios.post", "axios.put", "axios.delete",
      "axios.patch", "axios.head", "axios.options", "axios.request", "axios"
    ],
    "php": [
      "wp_remote_get", "wp_remote_post", "wp_remote_request",
      "curl_init", "file_get_contents", "fopen"
    ]
  },
  "external_services": {
    "anthropic": {
      "match": ["anthropic", "@anthropic-ai/sdk", "Anthropic\\Anthropic"],
      "match_urls": ["api\\.anthropic\\.com"],
      "label": "Anthropic"
    },
    "openai": {
      "match": ["openai", "OpenAI\\OpenAI", "openai/openai-python"],
      "match_urls": ["api\\.openai\\.com"],
      "label": "OpenAI"
    },
    "supabase": {
      "match": ["supabase", "@supabase/supabase-js"],
      "match_urls": [".*\\.supabase\\.co"],
      "label": "Supabase"
    },
    "stripe": {
      "match": ["stripe", "@stripe/stripe-js", "Stripe\\Stripe"],
      "match_urls": ["api\\.stripe\\.com"],
      "label": "Stripe"
    },
    "openrouter": {
      "match": ["openrouter"],
      "match_urls": ["openrouter\\.ai"],
      "label": "OpenRouter"
    },
    "gemini": {
      "match": ["@google/generative-ai", "google-generativeai"],
      "match_urls": ["generativelanguage\\.googleapis\\.com"],
      "label": "Gemini"
    },
    "chromadb": {
      "match": ["chromadb"],
      "label": "ChromaDB"
    },
    "firebase": {
      "match": ["firebase", "@firebase/app"],
      "match_urls": [".*\\.firebaseio\\.com"],
      "label": "Firebase"
    },
    "brave_search": {
      "match": [],
      "match_urls": ["api\\.search\\.brave\\.com"],
      "label": "Brave"
    },
    "duckduckgo": {
      "match": [],
      "match_urls": ["api\\.duckduckgo\\.com", "duckduckgo\\.com"],
      "label": "DuckDuckGo"
    },
    "context7": {
      "match": [],
      "match_urls": ["context7\\.com"],
      "label": "Context7"
    },
    "aws": {
      "match": ["boto3", "botocore", "@aws-sdk/client-s3"],
      "match_urls": [".*\\.amazonaws\\.com"],
      "label": "AWS"
    },
    "sendgrid": {
      "match": ["sendgrid", "@sendgrid/mail"],
      "match_urls": ["api\\.sendgrid\\.com"],
      "label": "SendGrid"
    },
    "twilio": {
      "match": ["twilio"],
      "match_urls": ["api\\.twilio\\.com"],
      "label": "Twilio"
    },
    "github_api": {
      "match": [],
      "match_urls": ["api\\.github\\.com"],
      "label": "GitHub API"
    },
    "huggingface": {
      "match": ["huggingface_hub", "transformers"],
      "match_urls": ["api-inference\\.huggingface\\.co", "huggingface\\.co"],
      "label": "HuggingFace"
    }
  },
  "definitions": [
    {
      "name": "Python-Patterns",
      "language": "python",
      "tier": "regex_fallback",
      "_comment": "Python usa PythonScanner (stdlib ast) para outbound — estas patterns NO se aplican al scanner primario, quedan como fallback documental. Los inbound siguen siendo útiles si algún día se agregan patterns específicas de Python (ej. @app.route). Hoy vacío porque la identidad 'Python' ya la resuelve stack_markers + StackDetector; duplicar aquí genera ruido en tech_scores (DEF-025).",
      "patterns": {
        "inbound": [],
        "outbound": []
      }
    },
    {
      "name": "PHP-Patterns",
      "language": "php",
      "tier": "regex_fallback",
      "_comment": "Outbound consolida patterns de WordPress-Development + Vanilla-Web-Stack-PHP (pre-DEF-025). Cubre: include/require literales, require __DIR__ . '/path' (PHP-inbound-019), wp_enqueue_script/style con ABSPATH/TEMPLATEPATH concatenado. EDG-023: cada pattern declara su edge_type para el label del .dot.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "include\\s*\\(?\\s*['\"]([^'\"]+)['\"]", "edge_type": "include" },
          { "regex": "require(?:_once)?\\s*\\(?\\s*['\"]([^'\"]+)['\"]", "edge_type": "require" },
          { "regex": "require(?:_once)?\\s+[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "require" },
          { "regex": "wp_enqueue_script\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "enqueue" },
          { "regex": "wp_enqueue_style\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "enqueue" }
        ]
      }
    },
    {
      "name": "JavaScript-Patterns",
      "language": "javascript",
      "tier": "regex_fallback",
      "_comment": "Outbound consolida patterns de Modern-Web-Stack-JS + Vanilla-Web-Stack-JS + Tauri-Desktop-App-JS (pre-DEF-025). EDG-023: edge_type por pattern. fetch→fetch, import→import, alias Next.js→import.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "import\\s+.+\\s+from\\s+['\"]([^'\"]+)['\"]", "edge_type": "import" },
          { "regex": "fetch\\s*\\(\\s*['\"]([^'\"]+)['\"]", "edge_type": "fetch" },
          { "regex": "from\\s+['\"]@/([^'\"]+)['\"]", "edge_type": "import" }
        ]
      }
    },
    {
      "name": "TypeScript-Patterns",
      "language": "typescript",
      "tier": "regex_fallback",
      "_comment": "TypeScript usa tree-sitter-typescript cuando la grammar está disponible. Patterns regex idénticas a JavaScript-Patterns como fallback Tier 3. EDG-023: edge_type por pattern.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "import\\s+.+\\s+from\\s+['\"]([^'\"]+)['\"]", "edge_type": "import" },
          { "regex": "fetch\\s*\\(\\s*['\"]([^'\"]+)['\"]", "edge_type": "fetch" },
          { "regex": "from\\s+['\"]@/([^'\"]+)['\"]", "edge_type": "import" }
        ]
      }
    },
    {
      "name": "HTML-Patterns",
      "language": "html",
      "tier": "regex_fallback",
      "_comment": "HTML usa HtmlScanner (hardcoded, HTML-019) que extrae src/href/action/form. Esta entry queda como placeholder para override futuro vía compass.local.json (ej. proyectos con atributos custom). Outbound vacío hoy — si el usuario lo define, se suma a lo que HtmlScanner ya captura.",
      "patterns": {
        "inbound": [],
        "outbound": []
      }
    }
  ]
}