{
  "basal_rules": {
    "ignore_folders": ["__pycache__", "node_modules", "dist", "build", "venv", ".venv", ".git", ".map", ".claude", "_archivo", "out", ".next", "src-tauri/target", "target", "gen", "bin", "obj", "vendor"],
    "text_extensions": [".py", ".js", ".jsx", ".ts", ".tsx", ".php", ".html", ".css", ".mjs", ".json", ".sql", ".env"],
    "network_triggers": ["http", "ws://", "api", "localhost", "fetch\\(", "wp_remote_", "requests\\.", "axios", "curl_init"],
    "persistence_triggers": ["global \\$wpdb", "get_option", "sql", "SELECT ", "INSERT INTO", "fs\\.", "localStorage", "sessionStorage", "ChromaDB", "prisma", "PDO", "mysqli_"],
    "identity_triggers": ["Plugin Name:", "export default function", "def main", "class ", "register_rest_route", "addEventListener", "index\\."],
    "unify_external_nodes": ["fetch", "anthropic", "chromadb", "openai", "axios", "requests"],
    "ignore_outbound_patterns": ["^self$", "^none$", "^$"]
  },
  "definitions": [
    {
      "name": "AI-Agent-Framework",
      "priority": 10,
      "indicators": {
        "files": ["bridge_windows.py", "requirements.txt", "indexar_filters.json"],
        "folders": ["engine", "skills", "agents", "tools"]
      },
      "patterns": {
        "inbound": ["@app\\.route", "async def", "def tool_", "def skill_"],
        "outbound": ["ChromaDB", "mcp_client", "openai", "anthropic", "requests\\.post", "bridge_leer"]
      }
    },
{
  "name": "Tauri-Desktop-App",
  "priority": 15,
  "indicators": {
    "files": ["tauri.conf.json", "Cargo.toml", "src-tauri/src/main.rs"],
    "folders": ["src-tauri", "src-tauri/src"]
  },
  "patterns": {
    "inbound": ["invoke\\(", "listen\\(", "emit\\(", "tauri::command"],
    "outbound": ["@tauri-apps/api", "window.__TAURI__", "command!", "manage!"]
  }
},
    {
      "name": "WordPress-Development",
      "priority": 10,
      "indicators": {
        "files": ["wp-config.php", "functions.php", "style.css"],
        "folders": ["wp-content", "wp-includes", "wp-admin"],
        "patterns_in_files": ["Plugin Name:", "Theme Name:", "Description:"]
      },
      "patterns": {
        "inbound": ["add_action\\(", "add_filter\\(", "do_action\\(", "register_rest_route"],
        "outbound": [
          "wp_remote_get",
          "get_option",
          "global \\$wpdb",
          "curl_exec",
          "update_post_meta",
          "wp_enqueue_script\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'",
"wp_enqueue_style\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'",
"require_once\\s+[A-Z_]+\\s*\\.\\s*'([^']+)'"
        ]
      }
    },
{
  "name": "Modern-Web-Stack (Next.js/React/Tauri-Frontend)",
  "priority": 10,
  "indicators": {
    "files": ["next.config.js", "package.json", "vite.config.ts", "tsconfig.json"],
    "folders": ["src", "app", "components", "hooks"]
  },
  "patterns": {
    "inbound": ["\"use client\"", "export default function", "const (.*) = (.*) =>"],
    "outbound": [
      "import .* from", 
      "fetch\\(", 
      "invoke\\(", 
      "supabase\\.", 
      "axios", 
      "from '@/(.*)'"
    ]
  }
},
    {
      "name": "Vanilla-Web-Stack (PHP/JS)",
      "priority": 5,
      "indicators": {
        "files": ["index.php", "index.html", "script.js", "style.css"],
        "patterns_in_files": ["<?php", "<script", "document.addEventListener"]
      },
      "patterns": {
        "inbound": [
          "function\\s+([\\w\\d_]+)\\s*\\(", 
          "(?:const|let|var)\\s+([\\w\\d_]+)\\s*=\\s*\\(",
          "addEventListener"
        ],
        "outbound": [
          "include\\s*\\(?\\s*['\"]([^'\"]+)['\"]", 
          "require(?:_once)?\\s*\\(?\\s*['\"]([^'\"]+)['\"]", 
          "header\\(", 
          "fetch\\(", 
          "document.querySelector"
        ]
      }
    }
  ]
}