{
  "basal_rules": {
    "ignore_folders": [
      "__pycache__",
      "node_modules",
      "dist",
      "build",
      "venv",
      ".venv",
      ".git",
      ".map",
      ".claude",
      "_archivo",
      "out",
      ".next",
      "src-tauri/target",
      "target",
      "gen",
      "bin",
      "obj",
      "vendor"
    ],
    "text_extensions": [
      ".py",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".php",
      ".html",
      ".htm",
      ".css",
      ".mjs",
      ".json",
      ".sql",
      ".env"
    ],
    "ignore_files": [],
    "ignore_patterns": [
      "__init__.py",
      "*.min.js",
      "*.min.css",
      "*.bundle.js",
      ".env",
      ".env.*",
      ".gitignore",
      ".gitattributes",
      ".editorconfig",
      ".prettierrc",
      ".prettierrc.*",
      ".eslintrc",
      ".eslintrc.*"
    ],
    "asset_extensions": [
      ".jpg", ".jpeg", ".png", ".webp", ".svg", ".ico", ".gif", ".bmp",
      ".woff", ".woff2", ".ttf", ".otf", ".eot",
      ".mp4", ".webm", ".mov", ".avi",
      ".mp3", ".wav", ".ogg",
      ".pdf", ".zip", ".tar", ".gz"
    ]
  },
  "stack_markers": {
    "WordPress-Development": {
      "lock_files": ["composer.json"],
      "framework_markers": ["wp-config.php", "functions.php"],
      "content_markers": ["Plugin Name:", "Theme Name:"]
    },
    "Modern-Web-Stack": {
      "lock_files": ["package-lock.json", "yarn.lock", "pnpm-lock.yaml"],
      "framework_markers": ["next.config.js", "vite.config.ts", "tsconfig.json"],
      "content_markers": ["\"use client\"", "export default function"]
    },
    "Tauri-Desktop-App": {
      "lock_files": ["Cargo.lock"],
      "framework_markers": ["tauri.conf.json", "src-tauri/src/main.rs"],
      "content_markers": ["tauri::command", "window.__TAURI__"]
    },
    "AI-Agent-Framework": {
      "lock_files": ["requirements.txt", "pyproject.toml"],
      "framework_markers": ["bridge_windows.py", "indexar_filters.json"],
      "content_markers": ["def tool_", "def skill_"]
    },
    "Vanilla-Web-Stack": {
      "lock_files": [],
      "framework_markers": ["index.php", "index.html"],
      "content_markers": ["<?php", "document.addEventListener"]
    },
    "Python": {
      "extensions": [".py", ".pyi"]
    },
    "JavaScript": {
      "extensions": [".js", ".mjs", ".cjs", ".jsx"]
    },
    "TypeScript": {
      "extensions": [".ts", ".tsx"]
    },
    "PHP": {
      "extensions": [".php"]
    },
    "Ruby": {
      "extensions": [".rb"]
    },
    "Go": {
      "extensions": [".go"]
    },
    "Rust": {
      "extensions": [".rs"]
    },
    "Java": {
      "extensions": [".java"]
    },
    "Web-Static": {
      "extensions": [".html", ".htm", ".css"]
    }
  },
  "language_grammars": {
    "php": "tree_sitter_php",
    "javascript": "tree_sitter_javascript",
    "typescript": "tree_sitter_typescript",
    "python": "stdlib_ast",
    "html": "regex_only"
  },
  "scoring": {
    "network_triggers": [
      "http",
      "ws://",
      "api",
      "localhost",
      "fetch\\(",
      "wp_remote_",
      "requests\\.",
      "axios",
      "curl_init"
    ],
    "persistence_triggers": [
      "global \\$wpdb",
      "get_option",
      "sql",
      "SELECT ",
      "INSERT INTO",
      "fs\\.",
      "localStorage",
      "sessionStorage",
      "ChromaDB",
      "prisma",
      "PDO",
      "mysqli_"
    ],
    "identity_triggers": [
      "Plugin Name:",
      "export default function",
      "def main",
      "class ",
      "register_rest_route",
      "addEventListener",
      "index\\."
    ]
  },
  "graph": {
    "unify_external_nodes": [
      "fetch",
      "anthropic",
      "chromadb",
      "openai",
      "axios",
      "requests"
    ],
    "ignore_outbound_patterns": [
      "^self$",
      "^none$",
      "^$"
    ],
    "rankdir": "LR",
    "vis_network_cdn_url": "https://unpkg.com/vis-network/standalone/umd/vis-network.min.js",
    "default_edge_type": "use",
    "edge_colors": {
      "import":  "#1f7a1f",
      "require": "#333333",
      "include": "#555555",
      "src":     "#1f5fbf",
      "href":    "#2e86de",
      "action":  "#8e44ad",
      "fetch":   "#c0392b",
      "enqueue": "#7d3c98",
      "use":     "#888888"
    },
    "node_colors": {
      "normal":   { "fillcolor": "#f5f5f5", "color": "#333333" },
      "orphan":   { "fillcolor": "#fff3cd", "color": "#b7791f" },
      "cycle":    { "fillcolor": "#fde0dc", "color": "#c0392b" },
      "external": { "fillcolor": "#ffcccc", "color": "#cc0000" }
    },
    "node_shapes": {
      "normal":   "box",
      "orphan":   "box",
      "cycle":    "box",
      "external": "cylinder"
    }
  },
  "scoring_weights": {
    "health_weights": {
      "orphans":       0.40,
      "connectivity":  0.30,
      "dead_exports":  0.15,
      "external_deps": 0.15
    }
  },
  "external_services": {
    "anthropic": {
      "match": ["anthropic", "@anthropic-ai/sdk", "Anthropic\\Anthropic"],
      "label": "Anthropic"
    },
    "openai": {
      "match": ["openai", "OpenAI\\OpenAI", "openai/openai-python"],
      "label": "OpenAI"
    },
    "supabase": {
      "match": ["supabase", "@supabase/supabase-js"],
      "label": "Supabase"
    },
    "stripe": {
      "match": ["stripe", "@stripe/stripe-js", "Stripe\\Stripe"],
      "label": "Stripe"
    },
    "openrouter": {
      "match": ["openrouter"],
      "label": "OpenRouter"
    },
    "gemini": {
      "match": ["@google/generative-ai", "google-generativeai"],
      "label": "Gemini"
    },
    "chromadb": {
      "match": ["chromadb"],
      "label": "ChromaDB"
    }
  },
  "definitions": [
    {
      "name": "Python-Patterns",
      "language": "python",
      "tier": "regex_fallback",
      "_comment": "Python usa PythonScanner (stdlib ast) para outbound — estas patterns NO se aplican al scanner primario, quedan como fallback documental. Los inbound siguen siendo útiles si algún día se agregan patterns específicas de Python (ej. @app.route). Hoy vacío porque la identidad 'Python' ya la resuelve stack_markers + StackDetector; duplicar aquí genera ruido en tech_scores (DEF-025).",
      "patterns": {
        "inbound": [],
        "outbound": []
      }
    },
    {
      "name": "PHP-Patterns",
      "language": "php",
      "tier": "regex_fallback",
      "_comment": "Outbound consolida patterns de WordPress-Development + Vanilla-Web-Stack-PHP (pre-DEF-025). Cubre: include/require literales, require __DIR__ . '/path' (PHP-inbound-019), wp_enqueue_script/style con ABSPATH/TEMPLATEPATH concatenado. EDG-023: cada pattern declara su edge_type para el label del .dot.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "include\\s*\\(?\\s*['\"]([^'\"]+)['\"]", "edge_type": "include" },
          { "regex": "require(?:_once)?\\s*\\(?\\s*['\"]([^'\"]+)['\"]", "edge_type": "require" },
          { "regex": "require(?:_once)?\\s+[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "require" },
          { "regex": "wp_enqueue_script\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "enqueue" },
          { "regex": "wp_enqueue_style\\s*\\(\\s*'[^']+'\\s*,\\s*[A-Z_]+\\s*\\.\\s*'([^']+)'", "edge_type": "enqueue" }
        ]
      }
    },
    {
      "name": "JavaScript-Patterns",
      "language": "javascript",
      "tier": "regex_fallback",
      "_comment": "Outbound consolida patterns de Modern-Web-Stack-JS + Vanilla-Web-Stack-JS + Tauri-Desktop-App-JS (pre-DEF-025). EDG-023: edge_type por pattern. fetch→fetch, import→import, alias Next.js→import.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "import\\s+.+\\s+from\\s+['\"]([^'\"]+)['\"]", "edge_type": "import" },
          { "regex": "fetch\\s*\\(\\s*['\"]([^'\"]+)['\"]", "edge_type": "fetch" },
          { "regex": "from\\s+['\"]@/([^'\"]+)['\"]", "edge_type": "import" }
        ]
      }
    },
    {
      "name": "TypeScript-Patterns",
      "language": "typescript",
      "tier": "regex_fallback",
      "_comment": "TypeScript usa tree-sitter-typescript cuando la grammar está disponible. Patterns regex idénticas a JavaScript-Patterns como fallback Tier 3. EDG-023: edge_type por pattern.",
      "patterns": {
        "inbound": [],
        "outbound": [
          { "regex": "import\\s+.+\\s+from\\s+['\"]([^'\"]+)['\"]", "edge_type": "import" },
          { "regex": "fetch\\s*\\(\\s*['\"]([^'\"]+)['\"]", "edge_type": "fetch" },
          { "regex": "from\\s+['\"]@/([^'\"]+)['\"]", "edge_type": "import" }
        ]
      }
    },
    {
      "name": "HTML-Patterns",
      "language": "html",
      "tier": "regex_fallback",
      "_comment": "HTML usa HtmlScanner (hardcoded, HTML-019) que extrae src/href/action/form. Esta entry queda como placeholder para override futuro vía compass.local.json (ej. proyectos con atributos custom). Outbound vacío hoy — si el usuario lo define, se suma a lo que HtmlScanner ya captura.",
      "patterns": {
        "inbound": [],
        "outbound": []
      }
    }
  ]
}