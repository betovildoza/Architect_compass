digraph G {
    rankdir=LR;
    concentrate=false; compound=true;
    graph [fontname="Arial", fontsize=12, labelloc="t", label="Architect's Compass — Connectivity Graph"];
    node [style="rounded,filled", fontname="Arial", fontsize=10];
    edge [arrowsize=0.7];
    subgraph "cluster__map" {
        label=".map";
        style="rounded,filled";
        fillcolor="#fafafa"; color="#cccccc";
        fontname="Arial"; fontsize=11;
        ".map/compass.local.json" [shape=box, fillcolor="#f5f5f5", color="#333333"];
    }
    subgraph "cluster_<root>" {
        label="<root>";
        style="rounded,filled";
        fillcolor="#fafafa"; color="#cccccc";
        fontname="Arial"; fontsize=11;
        "architect_compass.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "architect_symbols.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "mapper_config.json" [shape=box, fillcolor="#f5f5f5", color="#333333"];
    }
    subgraph "cluster_compass" {
        label="compass";
        style="rounded,filled";
        fillcolor="#fafafa"; color="#cccccc";
        fontname="Arial"; fontsize=11;
        "compass/__init__.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/cli.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/cli_ui.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/config_loader.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/consolidator.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/core.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/dashboard_detector.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/defaults.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/entry_points.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/finalize.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/framework_mounts.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/graph_emitter.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/metrics.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/orphan_classifier.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/outbound_resolver.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/path_resolver.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/pipeline.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scan_worker.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/__init__.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/base.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/html.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/python.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/regex_fallback.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/scanners/treesitter.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/stack_detector.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/stdlib_filter.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/template_io.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/templates/graph.html.tpl" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/validation.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
        "compass/wordpress_detector.py" [shape=box, fillcolor="#f5f5f5", color="#333333"];
    }
    "[EXTERNAL:rich]" [label="rich", shape=cylinder, style=filled, fillcolor="#ffcccc", color="#cc0000", fontname="Arial"];
    "[EXTERNAL:unpkg.com]" [label="unpkg.com", shape=cylinder, style=filled, fillcolor="#ffcccc", color="#cc0000", fontname="Arial"];
    "architect_compass.py" -> "compass/cli.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "architect_symbols.py" -> ".map/compass.local.json" [label="load", color="#888888", fontname="Arial", fontsize=9];
    "architect_symbols.py" -> "mapper_config.json" [label="load", color="#888888", fontname="Arial", fontsize=9];
    "compass.py" -> "compass/cli.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/__init__.py" -> "compass/core.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/__init__.py" -> "compass/path_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/__init__.py" -> "compass/scanners/__init__.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/__init__.py" -> "compass/stack_detector.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli.py" -> "architect_symbols.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli.py" -> "compass/cli_ui.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli.py" -> "compass/core.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli.py" -> "compass/graph_emitter.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli.py" -> "compass/template_io.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/cli_ui.py" -> "[EXTERNAL:rich]" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/config_loader.py" -> "compass/template_io.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/consolidator.py" -> "compass/stdlib_filter.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/config_loader.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/entry_points.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/finalize.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/outbound_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/path_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/pipeline.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/scan_worker.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/stack_detector.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/core.py" -> "compass/template_io.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/entry_points.py" -> "compass/framework_mounts.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/consolidator.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/dashboard_detector.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/graph_emitter.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/metrics.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/template_io.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/validation.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/finalize.py" -> "compass/wordpress_detector.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/graph_emitter.py" -> "[EXTERNAL:unpkg.com]" [label="fetch", color="#c0392b", fontname="Arial", fontsize=9];
    "compass/graph_emitter.py" -> "compass/templates/graph.html.tpl" [label="load", color="#888888", fontname="Arial", fontsize=9];
    "compass/outbound_resolver.py" -> "compass/stdlib_filter.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/path_resolver.py" -> "compass/defaults.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/path_resolver.py" -> "compass/framework_mounts.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/pipeline.py" -> "compass/defaults.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/pipeline.py" -> "compass/orphan_classifier.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/pipeline.py" -> "compass/scanners/__init__.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/pipeline.py" -> "compass/stack_detector.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scan_worker.py" -> "compass/pipeline.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scan_worker.py" -> "compass/scanners/__init__.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scan_worker.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/__init__.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/__init__.py" -> "compass/scanners/html.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/__init__.py" -> "compass/scanners/python.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/__init__.py" -> "compass/scanners/regex_fallback.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/__init__.py" -> "compass/scanners/treesitter.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/html.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/python.py" -> "compass/defaults.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/python.py" -> "compass/path_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/python.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/regex_fallback.py" -> "compass/path_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/regex_fallback.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/treesitter.py" -> "compass/path_resolver.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/treesitter.py" -> "compass/scanners/base.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    "compass/scanners/treesitter.py" -> "compass/scanners/regex_fallback.py" [label="import", color="#1f7a1f", fontname="Arial", fontsize=9];
    subgraph "cluster_legend" {
        label="Leyenda"; style="rounded,filled";
        fillcolor="#ffffff"; color="#999999";
        fontname="Arial"; fontsize=10; rank=sink;
        "_legend_node_normal" [label="normal", fillcolor="#f5f5f5", color="#333333", shape=box, style="rounded,filled", fontname="Arial", fontsize=9];
        "_legend_node_orphan" [label="orphan", fillcolor="#fff3cd", color="#b7791f", shape=box, style="rounded,filled", fontname="Arial", fontsize=9];
        "_legend_node_cycle" [label="cycle", fillcolor="#fde0dc", color="#c0392b", shape=box, style="rounded,filled", fontname="Arial", fontsize=9];
        "_legend_edge_fetch" [label="fetch", shape=plaintext, fontname="Arial", fontsize=9, fontcolor="#c0392b"];
        "_legend_edge_import" [label="import", shape=plaintext, fontname="Arial", fontsize=9, fontcolor="#1f7a1f"];
        "_legend_edge_fetch" -> "_legend_edge_import" [color="#1f7a1f", label="import", fontname="Arial", fontsize=8];
        "_legend_edge_load" [label="load", shape=plaintext, fontname="Arial", fontsize=9, fontcolor="#888888"];
        "_legend_edge_import" -> "_legend_edge_load" [color="#888888", label="load", fontname="Arial", fontsize=8];
    }
}
